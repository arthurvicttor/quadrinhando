generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Company {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  logoUrl     String?
  universes   Universe[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Universe {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  startYear   Int?
  companyId   Int
  company     Company  @relation(fields: [companyId], references: [id])
  comics      Comic[]
  events      Event[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comic {
  id               Int              @id @default(autoincrement())
  title            String
  volume           Int?             @default(1)
  issueNumber      Int?
  universeId       Int
  universe         Universe         @relation(fields: [universeId], references: [id])
  orderInUniverse  Int
  coverUrl         String?
  officialBuyLink  String?
  characters       ComicCharacter[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Character {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  imageUrl    String?
  comics      ComicCharacter[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ComicCharacter {
  id               Int       @id @default(autoincrement())
  comicId          Int
  characterId      Int
  appearanceOrder  Int       @default(0)
  comic            Comic     @relation(fields: [comicId], references: [id])
  character        Character @relation(fields: [characterId], references: [id])

  @@unique([comicId, characterId])
}

model Event {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  universeId  Int?
  universe    Universe? @relation(fields: [universeId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}